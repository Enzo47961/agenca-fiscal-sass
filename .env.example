# ============================================================
# Variáveis de ambiente — copie para .env.local (dev) e
# cadastre no Vercel (Settings → Environment Variables)
# ============================================================

# --- OBRIGATÓRIAS PARA O BUILD (sem elas o deploy falha) ---

# Supabase Dashboard → Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co

# Supabase Dashboard → Settings → API → anon/public key
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# Número do WhatsApp de suporte: só dígitos, com DDI e DDD
NEXT_PUBLIC_WHATSAPP_SUPORTE=5511999999999

# --- NECESSÁRIAS EM TEMPO DE EXECUÇÃO (funcionalidades específicas) ---

# Supabase Dashboard → Settings → API → service_role key (SECRETA!)
# Usada por: motor Inngest, webhook de pagamento
SUPABASE_URL=https://SEU-PROJETO.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# Token combinado no painel do Asaas para autenticar o webhook (mín. 16 chars)
# Usada por: /api/webhook/pagamento
ASAAS_WEBHOOK_TOKEN=troque-por-um-token-longo-e-aleatorio

# Chave de criptografia do certificado A1 (32 bytes em base64)
# Gerar com: openssl rand -base64 32
# Usada por: upload do certificado nas configurações
CERT_ENCRYPTION_KEY=

# Chave da API do Asaas (Configurações → Integrações). Sem ela, a tela de
# cobrança avisa que a integração não está configurada.
ASAAS_API_KEY=
# Produção: https://api.asaas.com/v3 (padrão é o sandbox)
ASAAS_BASE_URL=https://api-sandbox.asaas.com/v3

# E-mail transacional (resend.com). Sem a chave, o envio é pulado com log.
RESEND_API_KEY=
# Remetente — o domínio precisa estar verificado no Resend
EMAIL_REMETENTE="Agência Fiscal <notas@seudominio.com.br>"

# Opcional: taxa de falha simulada do provider mock (0 a 1)
MOCK_FISCAL_TAXA_FALHA=0.3
